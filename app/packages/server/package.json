{
  "name": "@exe/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "#server/*": "./src/*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@exe/domain": "0.1.0",
    "@exe/slack": "^0.1.0",
    "@google/genai": "^1.52.0",
    "@livekit/protocol": "^1.46.6",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.62.0",
    "@slack/types": "^2.21.1",
    "@slack/web-api": "^7.17.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.7.0",
    "livekit-server-sdk": "^2.15.4"
  }
}
