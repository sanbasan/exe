{
  "name": "@exe/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "lint": "eslint src test --max-warnings=0",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {}
}
