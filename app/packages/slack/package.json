{
  "name": "@exe/slack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "#slack/*": "./src/*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "lint": "eslint src --max-warnings=0",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@exe/domain": "0.1.0",
    "@slack/types": "^2.21.1"
  }
}
