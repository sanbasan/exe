{
  "name": "@exe/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.cjs' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.cjs' 'package.json' 'tsconfig.json' 'eslint.config.mjs'",
    "lint": "eslint src test --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@exe/domain": "0.1.0",
    "@exe/server": "^0.1.0",
    "@google/genai": "^1.52.0",
    "@livekit/agents": "^1.4.9",
    "@livekit/agents-plugin-google": "^1.4.9",
    "@livekit/agents-plugin-openai": "^1.4.9",
    "@sentry/node": "^10.62.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
