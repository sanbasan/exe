# App
EXE_ENV=dev
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_STORE_URL=TODO_YOUR_APP_STORE_URL
APP_REVIEW_TEST_ACCOUNT_EMAIL=testuser1@example.com
APP_REVIEW_TEST_SIGN_IN_CODE=123456
SENTRY_DSN=

# Firebase Admin
GOOGLE_CLOUD_PROJECT=your-project-dev
FIREBASE_CONFIG={"projectId":"your-project-dev","storageBucket":"your-project-dev.firebasestorage.app"}

# Slack
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# Gemini task extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_LATEST_INFO_MODEL=gemini-2.5-pro

# LiveKit
LIVEKIT_WS_URL=wss://TODO_YOUR_LIVEKIT_DOMAIN
NEXT_PUBLIC_LIVEKIT_WS_URL=wss://TODO_YOUR_LIVEKIT_DOMAIN
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=exe-task-review-agent
LIVEKIT_ROOM_NAME_PREFIX=exe-dev-
VM_INSTANCE_NAME=exe-livekit-dev
VM_PROJECT=your-project-dev
VM_ZONE=asia-northeast1-b
LIVEKIT_VM_AUTO_STOP_ENABLED=false
LIVEKIT_VM_IDLE_GRACE_MINUTES=10

# Push
APNS_BUNDLE_ID=com.example.exe.dev
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_AUTH_KEY=

# Security
ENCRYPTION_KEY=
