{
    "display_information": {
        "name": "exe",
        "description": "AI task management assistant living in Slack",
        "background_color": "#1a1a1a"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": true,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "exe",
            "always_online": true
        }
    },
    "oauth_config": {
        "redirect_urls": [
            "https://YOUR_APP_HOSTING_URL/api/slack/oauth_redirect"
        ],
        "scopes": {
            "bot": [
                "app_mentions:read",
                "bookmarks:read",
                "bookmarks:write",
                "canvases:read",
                "canvases:write",
                "channels:history",
                "channels:join",
                "channels:read",
                "channels:write.topic",
                "chat:write",
                "groups:history",
                "groups:read",
                "groups:write.topic",
                "im:history",
                "im:read",
                "im:write",
                "lists:read",
                "lists:write",
                "mpim:history",
                "mpim:read",
                "reactions:read",
                "team.billing:read",
                "team:read",
                "users:read",
                "users:read.email"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "request_url": "https://YOUR_APP_HOSTING_URL/api/slack/events",
            "bot_events": [
                "app_home_opened",
                "app_mention",
                "member_joined_channel",
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim",
                "reaction_added",
                "team_join",
                "user_change"
            ]
        },
        "interactivity": {
            "is_enabled": true,
            "request_url": "https://YOUR_APP_HOSTING_URL/api/slack/interactions"
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "token_rotation_enabled": true,
        "is_mcp_enabled": false
    }
}
