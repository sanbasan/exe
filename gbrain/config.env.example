# gbrain/config.env — deployment-specific values for the GBrain VM scripts.
#
# Copy this file to gbrain/config.env and fill in your own values:
#
#   cp gbrain/config.env.example gbrain/config.env
#
# config.env is gitignored at the repo root; never commit real project ids,
# domains, or VM names. Both scripts (setup.sh, deploy.sh) source config.env
# and map the _DEV / _PROD variables onto their working variables for the
# selected environment (--dev / --prod). Required variables fail fast if left
# empty.
#
# Non-identifying defaults (region, zone, machine type, disk size, GBrain ref,
# embedding/chat models) live inside the scripts, not here.

# --- Required: GCP project id per environment ---
PROJECT_DEV=your-project-dev
PROJECT_PROD=your-project-prod

# --- Required: GBrain VM name per environment ---
VM_NAME_DEV=exe-gbrain-dev
VM_NAME_PROD=exe-gbrain

# --- Required: public domain (Caddy TLS host, also the router base URL) ---
DOMAIN_DEV=gbrain-dev.example.com
DOMAIN_PROD=gbrain.example.com

# --- Optional: service-account short name (exe-* default used when unset) ---
# Projects differ per environment, so one name works for both dev and prod.
SA_NAME=exe-gbrain
