# Router runtime config (rendered onto the VM by setup.sh / deploy.sh as
# /opt/gbrain/.env). Values come from Secret Manager; nothing here is committed.
PORT=8080
PUBLIC_BASE_URL=https://gbrain.example.com

# Shared secrets (Secret Manager: GBRAIN_ROUTER_INGEST_TOKEN / _ADMIN_TOKEN).
# GBRAIN_ROUTER_INGEST_TOKEN must match the agent's GBRAIN_INGEST_TOKEN.
GBRAIN_ROUTER_INGEST_TOKEN=
GBRAIN_ROUTER_ADMIN_TOKEN=

# Embedding/LLM provider used by every per-workspace brain. Backends stay on
# Google (Gemini): GBRAIN_MODEL drives chat-shaped work (facts extraction,
# think, dream); the embedding model runs at 1536 dims so brains created on
# the previous openai:text-embedding-3-small stay column-compatible (after
# switching an existing brain, re-embed with `gbrain embed --all`).
# OPENAI_API_KEY remains only as a legacy fallback for pre-switch brains.
GOOGLE_GENERATIVE_AI_API_KEY=
GBRAIN_MODEL=google:gemini-2.5-flash
GBRAIN_EMBEDDING_MODEL=google:gemini-embedding-001
GBRAIN_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# Per-workspace brain storage + GBrain revision pin.
GBRAIN_DATA_DIR=/data/brains
GBRAIN_REF=master

# Postgres (one database per workspace: gbrain_ws_<workspaceId>).
PGHOST=postgres
PGPORT=5432
PGUSER=gbrain
PGPASSWORD=

# Optional tuning (defaults shown):
# GBRAIN_SERVE_IDLE_TTL_MS=600000   # reap an idle per-workspace serve after 10m
# GBRAIN_SERVE_MAX_WARM=8           # LRU cap on concurrently-warm serves
# GBRAIN_SERVE_PORT_BASE=3200       # ephemeral port range base for serves
