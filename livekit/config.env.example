# livekit/config.env — deployment-specific values for the LiveKit VM scripts.
#
# Copy this file to livekit/config.env and fill in your own values:
#
#   cp livekit/config.env.example livekit/config.env
#
# config.env is gitignored at the repo root; never commit real project ids,
# domains, or VM names. Every script (setup.sh, deploy.sh, agent-pool.sh,
# build-agent-vm-image.sh) sources config.env and maps the _DEV / _PROD
# variables onto its working variables for the selected environment
# (--dev / --prod). Required variables fail fast if left empty.
#
# Non-identifying defaults (region, zone, machine type, disk size, ports,
# thresholds, agent name, room prefix) live inside the scripts, not here.

# --- Required: GCP project id per environment ---
PROJECT_DEV=your-project-dev
PROJECT_PROD=your-project-prod

# --- Required: LiveKit server VM name per environment ---
VM_NAME_DEV=exe-livekit-dev
VM_NAME_PROD=exe-livekit

# --- Required: public domain (Caddy TLS host, also the wss:// LiveKit URL) ---
DOMAIN_DEV=livekit-dev.example.com
DOMAIN_PROD=livekit.example.com

# --- Required: backend URL the agent calls back into (App Hosting or similar) ---
APP_URL_DEV=https://your-app-dev.example.com
APP_URL_PROD=https://your-app.example.com

# --- Optional: GBrain memory-service domain per environment ---
# Leave empty to disable the (optional) GBrain integration for that environment.
GBRAIN_DOMAIN_DEV=
GBRAIN_DOMAIN_PROD=

# --- Optional: service-account short names (exe-* defaults used when unset) ---
# Projects differ per environment, so one name works for both dev and prod.
SA_NAME=exe-livekit               # LiveKit server VM SA (setup.sh)
AGENT_SA_NAME=exe-livekit-agent   # agent pool SA (agent-pool.sh, build-agent-vm-image.sh)
